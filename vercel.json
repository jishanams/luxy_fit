{
  "version": 2,
  "name": "luxytrends-ai-tryon",
  "builds": [
    {
      "src": "luxytrends_backend/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "luxytrends_backend/wsgi.py"
    }
  ]
}