# Required: create key from FASHN API dashboard
FASHN_API_KEY=paste_your_fashn_api_key_here

# Required for local testing because FASHN must read uploaded images from a public URL.
# Example with ngrok: PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app
PUBLIC_BASE_URL=http://localhost:3000

# Optional default garment image. Use your real product/garment image URL here.
# Important: for FASHN tryon-v1.6 this must be garment_image, not product_image.
PRODUCT_GARMENT_IMAGE_URL=https://images.unsplash.com/photo-1555252333-9f8e92e65df9?w=1000&q=80

PORT=3000
